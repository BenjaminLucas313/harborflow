# Database — PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://harborflow:harborflow@localhost:5432/harborflow_dev"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""

# App URL — used by Auth.js for callbacks
AUTH_URL="http://localhost:3000"

# Anthropic API key — required for UABL Assistant and AI recommendations
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
