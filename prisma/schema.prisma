// =============================================================================
// HarborFlow — Prisma Schema V2
// Multi-tenant launch reservation and operations platform
//
// V2 DESIGN CHANGES
// -----------------
// The role model was restructured based on a domain relevamiento:
//
//   PASSENGER → USUARIO  : individual worker/inspector — view-only, cannot self-book
//   OPERATOR  → PROVEEDOR: boat operator — manages fleet and port status
//   ADMIN     → UABL     : port authority — approves reservations by department
//   (new)       EMPRESA  : companies that book seats in bulk for employees
//
// Key behavioral change: individual reservations (Reservation model) are
// replaced by a group booking flow:
//   GroupBooking (EMPRESA creates) → PassengerSlot (one per seat, links to USUARIO)
//   → UABL department approves/rejects each slot based on WorkType
//
// Reservation and WaitlistEntry are kept for migration safety but are
// soft-deprecated. They will be dropped in a V3 cleanup migration.
//
// DESIGN PRINCIPLES (carried over from V1)
// -----------------------------------------
// 1. Every tenant-owned entity carries companyId. Branch-scoped entities
//    additionally carry branchId (sometimes denormalized for query efficiency).
// 2. TripStatus does NOT include FULL. Full/availability is always derived
//    by counting PENDING + CONFIRMED PassengerSlots against trip.capacity.
// 3. Trip.capacity is a snapshot of Boat.capacity at trip creation time.
// 4. PortStatus is an append-only event log. Current status = latest record
//    for a branch ordered by createdAt DESC. No updatedAt.
// 5. AuditLog is immutable. No updates, no deletes. actorId is nullable
//    to support system-triggered events.
// 6. Capacity enforcement uses SELECT ... FOR UPDATE inside a transaction
//    to prevent the last-seat race condition.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

/// Active role model (V2). Legacy values are kept in the enum only because
/// they may still exist in the database — they must never be assigned to
/// new users and are not reachable through any UI or API.
///
/// USUARIO   : individual worker/inspector — can only view their assigned trips
/// EMPRESA   : company coordinator — creates GroupBookings for their employees
/// UABL      : port authority reviewer — approves/rejects PassengerSlots by dept
/// PROVEEDOR : boat operator — manages fleet, trips, and port status
enum UserRole {
  // ── DEPRECATED — do not use. May still exist in DB rows from V1.
  // ── The middleware redirects these to /login. No UI or API accepts them.
  // ── Safe to DROP in a future migration once all rows are migrated.
  PASSENGER
  OPERATOR
  ADMIN

  // ── V2 active values ──────────────────────────────────────────────
  USUARIO
  EMPRESA
  UABL
  PROVEEDOR
}

/// Operational lifecycle of a scheduled trip. Unchanged from V1.
/// FULL is intentionally absent — it is a derived state, not stored.
enum TripStatus {
  SCHEDULED
  BOARDING
  DELAYED
  CANCELLED
  DEPARTED
  COMPLETED
}

/// V1 reservation status — kept for legacy Reservation model.
/// @deprecated Use SlotStatus for V2 booking flows.
enum ReservationStatus {
  CONFIRMED
  WAITLISTED
  REPLACED
  CANCELLED
  CHECKED_IN
  NO_SHOW
}

/// V1 waitlist status — kept for legacy WaitlistEntry model.
/// @deprecated Not used in V2 booking flows.
enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
  EXPIRED
}

/// Lifecycle of a GroupBooking (EMPRESA → UABL approval flow).
///
/// DRAFT     : EMPRESA is assembling the passenger list. Slots can be added/removed.
/// SUBMITTED : Sent to UABL for review. No more slot additions allowed.
/// PARTIAL   : Some slots confirmed, others still pending or rejected.
/// CONFIRMED : All non-cancelled slots are confirmed by UABL.
/// CANCELLED : Entire booking was cancelled by EMPRESA.
enum GroupBookingStatus {
  DRAFT
  SUBMITTED
  PARTIAL
  CONFIRMED
  CANCELLED
}

/// Lifecycle of an individual PassengerSlot within a GroupBooking.
///
/// PENDING   : Awaiting review by the UABL department responsible for this WorkType.
/// CONFIRMED : Approved by the responsible UABL department user.
/// REJECTED  : Rejected by UABL (rejectionNote should explain why).
/// CANCELLED : Cancelled by EMPRESA after submission, or when GroupBooking is cancelled.
enum SlotStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

/// Operational state values for a port / branch. Unchanged from V1.
enum PortStatusValue {
  OPEN
  PARTIALLY_OPEN
  CLOSED_WEATHER
  CLOSED_MAINTENANCE
  CLOSED_SECURITY
  CLOSED_OTHER
}

/// Strongly-typed audit action catalog.
/// V2 adds group booking and slot lifecycle actions.
enum AuditAction {
  // ── V1: Reservation lifecycle (legacy) ───────────────────────────────────
  RESERVATION_CREATED
  RESERVATION_REPLACED
  RESERVATION_CANCELLED
  RESERVATION_CHECKED_IN
  RESERVATION_NO_SHOW
  // ── V1: Waitlist lifecycle (legacy) ──────────────────────────────────────
  WAITLIST_JOINED
  WAITLIST_PROMOTED
  WAITLIST_CANCELLED
  WAITLIST_EXPIRED
  // ── V1: Trip operations ───────────────────────────────────────────────────
  TRIP_CREATED
  TRIP_STATUS_CHANGED
  TRIP_CAPACITY_CHANGED
  // ── V1: Port operations ───────────────────────────────────────────────────
  PORT_STATUS_CHANGED
  // ── V1: Notices ───────────────────────────────────────────────────────────
  NOTICE_CREATED
  NOTICE_DEACTIVATED
  // ── V1: User / role management ────────────────────────────────────────────
  USER_CREATED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  // ── V2: Group booking lifecycle ───────────────────────────────────────────
  GROUP_BOOKING_CREATED
  GROUP_BOOKING_SUBMITTED
  GROUP_BOOKING_CANCELLED
  GROUP_BOOKING_SLOT_ADDED
  // ── V2: Passenger slot lifecycle ──────────────────────────────────────────
  SLOT_CONFIRMED
  SLOT_REJECTED
  SLOT_CANCELLED
  SLOT_REVERTED
  // ── V2: Admin/configuration operations ───────────────────────────────────
  DEPARTMENT_CREATED
  DEPARTMENT_UPDATED
  WORKTYPE_CREATED
  WORKTYPE_UPDATED
  EMPLOYER_CREATED
  EMPLOYER_UPDATED
  // ── V2: TripRequest lifecycle ─────────────────────────────────────────────
  TRIP_REQUEST_CREATED
  TRIP_REQUEST_ACCEPTED
  TRIP_REQUEST_REJECTED
  TRIP_REQUEST_CANCELLED
  // ── V2: Liquidación de asientos ───────────────────────────────────────────
  LIQUIDACION_CALCULADA
  LIQUIDACION_RECALCULADA
  VIAJE_MARCADO_PASADO
  // ── V2: Anomaly detection ─────────────────────────────────────────────────
  ANOMALIA_NOTIFICADA
  // ── V2: Narrative reports ─────────────────────────────────────────────────
  INFORME_GENERADO
}

/// Status lifecycle for on-demand boat requests submitted by EMPRESA.
///
/// PENDING    → ACCEPTED (PROVEEDOR picks a boat, Trip is auto-created)
/// PENDING    → REJECTED (PROVEEDOR declines)
/// PENDING    → CANCELLED (EMPRESA cancels before review)
/// ACCEPTED   → FULFILLED (Trip successfully created — terminal state)
enum TripRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  FULFILLED
}

/// Priority level for AI-generated operational recommendations.
enum PrioridadIA {
  ALTA
  MEDIA
  BAJA
}

/// Lifecycle of an AI recommendation from generation to resolution.
enum EstadoRecomendacion {
  ACTIVA
  IMPLEMENTADA
  DESCARTADA
}

/// Lifecycle state of a trip from the liquidation module's perspective.
///
/// This is distinct from TripStatus (which tracks operational state) and
/// is used exclusively by the settlement/liquidation flow.
///
/// ACTIVO   : Trip is upcoming or currently in progress — not yet eligible for liquidation.
/// PASADO   : Trip has been completed (departed/completed) — eligible for liquidation calculation.
/// CANCELADO: Trip was cancelled — excluded from liquidation.
///
/// Transition rules:
///   - Set to PASADO when TripStatus transitions to DEPARTED or COMPLETED.
///   - Set to CANCELADO when TripStatus transitions to CANCELLED.
///   - Only trips in PASADO state can have AsientoLiquidacion records calculated.
enum ViajeStatus {
  ACTIVO
  PASADO
  CANCELADO
}

// =============================================================================
// TENANT LAYER — Company & Branch
// =============================================================================

/// Top-level tenant. All tenant-owned entities carry companyId.
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches            Branch[]
  users               User[]
  boats               Boat[]
  drivers             Driver[]
  trips               Trip[]
  // V1 legacy
  reservations        Reservation[]
  waitlistEntries     WaitlistEntry[]
  // V2
  employers           Employer[]
  departments         Department[]
  workTypes           WorkType[]
  groupBookings       GroupBooking[]
  passengerSlots      PassengerSlot[]
  //
  portStatuses        PortStatus[]
  operationalNotices  OperationalNotice[]
  checkIns            CheckIn[]
  auditLogs           AuditLog[]
  tripRequests        TripRequest[]
  asientosLiquidacion AsientoLiquidacion[]
  recomendacionesIA   RecomendacionIA[]
  snapshotsMensuales  SnapshotMensual[]
  informesNarrativos  InformeNarrativo[]
}

/// Operational location (port / dock / service point) within a company.
model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  boats              Boat[]
  drivers            Driver[]
  trips              Trip[]
  portStatuses       PortStatus[]
  operationalNotices OperationalNotice[]
  users              User[]
  // V1 legacy
  reservations       Reservation[]
  waitlistEntries    WaitlistEntry[]
  // V2
  groupBookings      GroupBooking[]
  passengerSlots     PassengerSlot[]
  tripRequests       TripRequest[]
  asientosLiquidacion AsientoLiquidacion[]

  @@index([companyId])
}

// =============================================================================
// USER
// =============================================================================

/// Users are always scoped to a company.
///
/// V2 ADDITIONS:
/// - departmentId: for UABL users — scopes which slots they can review
/// - employerId  : for EMPRESA users — the business entity they book on behalf of
/// - isUablAdmin : UABL sub-role; allows managing departments and work types
///
/// A UABL user without departmentId cannot review any slot.
/// A UABL user with isUablAdmin=true can also manage departments and work types
/// (but still requires a departmentId for slot review).
model User {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String?
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         UserRole @default(USUARIO)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// For UABL role: the department this user is authorized to review slots for.
  departmentId String?
  /// For EMPRESA role: the employer entity this user books on behalf of.
  employerId   String?
  /// For UABL role: if true, can manage departments and work types (admin sub-role).
  isUablAdmin  Boolean  @default(false)

  company    Company     @relation(fields: [companyId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  employer   Employer?   @relation(fields: [employerId], references: [id])

  // V1 legacy
  reservations       Reservation[]
  waitlistEntries    WaitlistEntry[]
  checkInsPerformed  CheckIn[]           @relation("CheckInOperator")
  portStatusChanges  PortStatus[]        @relation("PortStatusActor")
  noticesCreated     OperationalNotice[]
  auditLogsAsActor   AuditLog[]          @relation("AuditActor")

  // V2
  /// PassengerSlots where this USUARIO is the assigned passenger.
  assignedSlots      PassengerSlot[]     @relation("SlotUsuario")
  /// PassengerSlots this UABL user has reviewed (confirmed or rejected).
  reviewedSlots      PassengerSlot[]     @relation("SlotReviewer")
  /// GroupBookings created by this EMPRESA user.
  groupBookings      GroupBooking[]      @relation("GroupBookingCreator")
  /// TripRequests submitted by this EMPRESA user.
  tripRequestsCreated   TripRequest[]   @relation("TripRequestCreator")
  /// TripRequests reviewed (accepted/rejected) by this PROVEEDOR user.
  tripRequestsReviewed  TripRequest[]   @relation("TripRequestReviewer")

  @@unique([companyId, email])
  @@index([companyId, role])
  @@index([companyId, branchId])
  @@index([companyId, departmentId])
  @@index([companyId, employerId])
}

// =============================================================================
// V2 — EMPLOYER (Business entity for EMPRESA role)
// =============================================================================

/// Represents a company/employer entity in the real world.
/// Distinct from the platform Company (tenant) — an Employer is a client
/// organization whose EMPRESA users book seats for their employees.
///
/// One Employer can have many EMPRESA User accounts.
/// One Employer can create many GroupBookings across different trips.
model Employer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  /// Optional tax ID (CUIT/NIT) for record-keeping.
  taxId     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  /// EMPRESA users associated with this employer.
  users         User[]
  groupBookings GroupBooking[]

  @@unique([companyId, taxId])
  @@index([companyId])
  @@index([companyId, isActive])
}

// =============================================================================
// V2 — DEPARTMENT & WORKTYPE (UABL departmentalization)
// =============================================================================

/// A department within UABL. Loaded by UABL admin.
/// Each department is responsible for reviewing slots with WorkTypes assigned to it.
/// The set of departments is fixed/stable — changes require UABL admin action.
model Department {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  description   String?
  /// Contact email for the department (used for liquidation notifications). Nullable.
  emailContacto String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company        Company              @relation(fields: [companyId], references: [id])
  /// Work types that belong to this department.
  workTypes      WorkType[]
  /// UABL users assigned to review slots for this department.
  users          User[]
  /// Slots assigned to this department (denormalized from workType for query efficiency).
  passengerSlots PassengerSlot[]
  /// V1 legacy reservations linked to this department (nullable FK on Reservation).
  reservationsLegacy Reservation[]    @relation("DepartmentReservation")
  /// Liquidation records for this department (one per trip where the dept had seats).
  asientosLiquidacion AsientoLiquidacion[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, isActive])
}

/// A type of work performed by a passenger on a trip.
/// Belongs to exactly one Department — when an EMPRESA assigns a WorkType to
/// a passenger slot, that slot is routed to the corresponding UABL department
/// for approval.
///
/// WorkTypes are a closed list managed by UABL admin.
model WorkType {
  id           String   @id @default(cuid())
  companyId    String
  departmentId String
  name         String
  /// Short code for display / filtering (e.g. "MAINT", "INSPECT", "LOG").
  code         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  department     Department      @relation(fields: [departmentId], references: [id])
  passengerSlots PassengerSlot[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, departmentId])
  @@index([companyId, isActive])
}

// =============================================================================
// V2 — GROUP BOOKING & PASSENGER SLOT
// =============================================================================

/// A bulk booking created by an EMPRESA user for one trip.
/// Contains one or many PassengerSlots (one per seat requested).
///
/// LIFECYCLE
/// ---------
/// DRAFT → EMPRESA adds passengers (slots). Slots can be added or removed.
/// SUBMITTED → EMPRESA locks the booking and sends it for UABL review.
///   - No more slot additions after this point.
///   - Each slot's departmentId determines which UABL user reviews it.
/// PARTIAL → At least one slot confirmed, at least one still pending.
/// CONFIRMED → All non-cancelled slots are confirmed.
/// CANCELLED → EMPRESA cancelled the booking.
///
/// CAPACITY IMPACT
/// ---------------
/// Capacity consumed = COUNT(PassengerSlot WHERE tripId = X AND status IN ('PENDING','CONFIRMED'))
/// PENDING slots consume capacity (they are tentatively held).
/// REJECTED and CANCELLED slots release capacity.
///
/// An EMPRESA can have multiple GroupBookings for the same trip (distinct groups).
/// There is no limit on how many bookings an EMPRESA can create across trips.
model GroupBooking {
  id         String             @id @default(cuid())
  companyId  String
  /// Denormalized from trip for branch-scoped queries.
  branchId   String
  tripId     String
  employerId String
  /// The EMPRESA User who created this booking.
  bookedById String
  status     GroupBookingStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id])
  trip           Trip            @relation(fields: [tripId], references: [id])
  employer       Employer        @relation(fields: [employerId], references: [id])
  bookedBy       User            @relation("GroupBookingCreator", fields: [bookedById], references: [id])
  passengerSlots PassengerSlot[]

  /// All bookings for a specific trip (capacity management, UABL view).
  @@index([companyId, tripId])
  /// EMPRESA view: all bookings by this employer with a given status.
  @@index([employerId, status])
  /// Branch-scoped booking list (PROVEEDOR / UABL view).
  @@index([branchId, status])
  /// Who created this booking.
  @@index([bookedById])
}

/// One seat within a GroupBooking, assigned to a specific USUARIO account.
///
/// ROUTING
/// -------
/// workTypeId → workType.departmentId determines which UABL department reviews this slot.
/// departmentId is denormalized here for direct queries without a JOIN through WorkType.
///
/// UNIQUENESS CONSTRAINT
/// ----------------------
/// @@unique([tripId, usuarioId]): a USUARIO cannot be assigned twice to the same trip,
/// regardless of which GroupBooking they are in. This is the V2 equivalent of the
/// V1 partial unique index on Reservation.
///
/// STATUS TRANSITIONS
/// ------------------
/// PENDING → CONFIRMED (UABL approves) or REJECTED (UABL rejects)
/// PENDING → CANCELLED (EMPRESA cancels before UABL acts)
/// CONFIRMED → CANCELLED is discouraged (requires GroupBooking cancellation)
model PassengerSlot {
  id             String     @id @default(cuid())
  companyId      String
  groupBookingId String
  /// Denormalized from groupBooking for direct trip queries.
  tripId         String
  /// Denormalized from groupBooking for branch-scoped queries.
  branchId       String
  /// The USUARIO account being assigned to this seat.
  usuarioId      String
  workTypeId     String
  /// Denormalized from workType.departmentId for direct department queries.
  departmentId   String
  /// The company/organization the USUARIO is representing on this trip.
  representedCompany String

  status        SlotStatus @default(PENDING)
  /// The UABL user who confirmed or rejected this slot.
  reviewedById  String?
  reviewedAt    DateTime?
  /// Required when status = REJECTED.
  rejectionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  groupBooking GroupBooking @relation(fields: [groupBookingId], references: [id])
  trip         Trip         @relation(fields: [tripId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  /// The passenger being assigned to this seat.
  usuario      User         @relation("SlotUsuario", fields: [usuarioId], references: [id])
  workType     WorkType     @relation(fields: [workTypeId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  /// The UABL user who reviewed this slot.
  reviewedBy   User?        @relation("SlotReviewer", fields: [reviewedById], references: [id])

  /// A USUARIO can only appear once per trip (across all GroupBookings).
  /// This is the V2 equivalent of the V1 reservation_one_active_per_user partial index.
  @@unique([tripId, usuarioId])

  /// All slots for a specific GroupBooking (status overview).
  @@index([groupBookingId])
  /// Capacity counting and trip manifest: all active slots for a trip.
  @@index([tripId, status])
  /// UABL department view: pending slots for their department.
  @@index([departmentId, status])
  /// USUARIO view: all trips they are assigned to.
  @@index([usuarioId, status])
  /// Company-scoped trip slot queries.
  @@index([companyId, tripId])
  /// Branch-scoped slot queries.
  @@index([branchId, status])
}

// =============================================================================
// FLEET — Boat & Driver
// =============================================================================

/// A vessel belonging to a company and assigned to a branch.
/// capacity is the master value from which Trip.capacity is snapshotted.
/// Changing capacity here does NOT retroactively change existing trips.
/// In V2, managed by PROVEEDOR users.
model Boat {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String
  name        String
  capacity    Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  trips   Trip[]
  tripRequests TripRequest[]

  @@index([companyId])
  @@index([branchId])
}

/// A pilot / captain assigned to trips.
/// In V2, managed by PROVEEDOR users.
model Driver {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String
  firstName     String
  lastName      String
  licenseNumber String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  trips   Trip[]

  @@index([companyId])
  @@index([branchId])
}

// =============================================================================
// TRIP
// =============================================================================

/// A scheduled departure. The core reservable unit.
///
/// In V2, trips are created by PROVEEDOR users.
/// GroupBookings reference trips. PassengerSlots are children of GroupBookings.
///
/// capacity is a SNAPSHOT of boat.capacity at the time of trip creation.
/// This is intentional: boat edits must not affect bookings already made.
///
/// V2 CAPACITY RULE:
/// Seats consumed = COUNT(PassengerSlot WHERE tripId = X AND status IN ('PENDING','CONFIRMED'))
/// PENDING slots hold capacity. REJECTED and CANCELLED slots release it.
model Trip {
  id                   String      @id @default(cuid())
  companyId            String
  branchId             String
  boatId               String
  driverId             String?
  departureTime        DateTime
  estimatedArrivalTime DateTime?
  /// Operational lifecycle status (SCHEDULED → BOARDING → DEPARTED → COMPLETED, etc.)
  status               TripStatus  @default(SCHEDULED)
  /// Snapshot of boat.capacity at trip creation. Immutable post-creation.
  capacity             Int
  waitlistEnabled      Boolean     @default(true)
  statusReason         String?
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  /// Liquidation lifecycle status. Distinct from operational `status`.
  /// Transitions: ACTIVO → PASADO (on DEPARTED/COMPLETED) or CANCELADO (on CANCELLED).
  /// Only trips in PASADO state are eligible for AsientoLiquidacion calculation.
  viajeStatus          ViajeStatus @default(ACTIVO)
  /// Flag set to true once AsientoLiquidacion records have been computed for this trip.
  /// Prevents accidental double-calculation. Reset to false if recalculation is triggered.
  liquidacionCalculada Boolean     @default(false)

  /// If true, a daily job will auto-create a copy of this trip for the next day.
  automatizado         Boolean     @default(false)
  /// Fixed time-of-day for auto-scheduling, stored as "HH:MM" (Argentina local time, UTC-3).
  /// Required when automatizado = true. Ignored otherwise.
  horaRecurrente       String?

  company            Company             @relation(fields: [companyId], references: [id])
  branch             Branch              @relation(fields: [branchId], references: [id])
  boat               Boat                @relation(fields: [boatId], references: [id])
  driver             Driver?             @relation(fields: [driverId], references: [id])
  // V1 legacy
  reservations       Reservation[]
  waitlistEntries    WaitlistEntry[]
  checkIns           CheckIn[]
  // V2
  groupBookings      GroupBooking[]
  passengerSlots     PassengerSlot[]
  operationalNotices OperationalNotice[]
  /// If this trip was auto-created from a TripRequest on acceptance.
  tripRequest        TripRequest?
  /// Liquidation records for this trip (one per department that had seats).
  asientosLiquidacion AsientoLiquidacion[]

  @@index([branchId, departureTime, status])
  @@index([companyId, departureTime])
  @@index([companyId, status])
  /// Query trips eligible for liquidation calculation.
  @@index([companyId, viajeStatus, liquidacionCalculada])
}

// =============================================================================
// TRIPREQUEST — On-demand boat request (EMPRESA → PROVEEDOR)
// =============================================================================

/// An on-demand boat request submitted by an EMPRESA user.
/// Represents a "request a boat" flow analogous to a ride-hailing request.
///
/// Lifecycle:
///   EMPRESA submits → PENDING
///   PROVEEDOR accepts (picks a boat) → Trip auto-created → FULFILLED
///   PROVEEDOR rejects → REJECTED
///   EMPRESA cancels before review → CANCELLED
///
/// On acceptance, a Trip record is created automatically and tripId is set.
/// The existing manual trip creation flow is unaffected.
model TripRequest {
  id             String            @id @default(cuid())
  companyId      String
  /// Optional — solicitudes are not tied to a specific branch. Origin/destination are explicit text fields.
  branchId       String?
  origin         String
  destination    String
  requestedDate  DateTime
  passengerCount Int
  notes          String?
  status         TripRequestStatus @default(PENDING)
  requestedById  String
  /// Set by PROVEEDOR when accepting — which boat will cover this trip.
  boatId         String?
  /// Created automatically when PROVEEDOR accepts. Foreign key to the new Trip.
  tripId         String?           @unique
  /// PROVEEDOR user who accepted or rejected.
  reviewedById   String?
  reviewedAt     DateTime?
  rejectionNote        String?
  /// Optional reason provided by the EMPRESA user when self-cancelling.
  motivoCancelacion    String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  company     Company  @relation(fields: [companyId], references: [id])
  branch      Branch?  @relation(fields: [branchId], references: [id])
  requestedBy User     @relation("TripRequestCreator", fields: [requestedById], references: [id])
  boat        Boat?    @relation(fields: [boatId], references: [id])
  trip        Trip?    @relation(fields: [tripId], references: [id])
  reviewedBy  User?    @relation("TripRequestReviewer", fields: [reviewedById], references: [id])

  @@index([companyId, status])
  @@index([branchId, status])
  @@index([requestedById])
}

// =============================================================================
// ASIENTO LIQUIDACION — Seat settlement per trip per department
// =============================================================================

/// Settlement record for one department's proportional seat cost on a single trip.
///
/// BUSINESS RULE:
/// --------------
/// After a trip is completed (viajeStatus = PASADO), the liquidation engine:
///   1. Counts reserved seats per department (asientosReservados).
///   2. Calculates each department's proportional share of empty seats:
///        fraccionVacios = vacios * (asientosReservados[dept] / totalOcupados)
///   3. Stores totalAsientos = asientosReservados + fraccionVacios.
///
/// Example (10 seats, 6 occupied: dept A=3, B=2, C=1 → 4 vacíos):
///   dept A: fraccionVacios = 4 * (3/6) = 2.0000  → totalAsientos = 5.0000
///   dept B: fraccionVacios = 4 * (2/6) = 1.3333  → totalAsientos = 3.3333
///   dept C: fraccionVacios = 4 * (1/6) = 0.6667  → totalAsientos = 1.6667
///   Sum of totalAsientos = 10 ✓
///
/// UNIQUENESS: One record per (trip, department). Recalculation deletes and
/// recreates the row (handled by the liquidation service).
///
/// IMMUTABILITY: Once liquidacionCalculada = true on the parent Trip, records
/// should not be modified without an explicit LIQUIDACION_RECALCULADA audit event.
///
/// NOTE: `anio` uses ASCII spelling of "año" to avoid Unicode identifier issues
/// in TypeScript tooling.
model AsientoLiquidacion {
  id                 String   @id @default(cuid())
  /// Tenant scope — mandatory for all tenant-owned entities.
  companyId          String
  /// Denormalized from viaje.branchId for branch-scoped queries without a JOIN.
  branchId           String
  /// The trip this settlement record belongs to.
  viajeId            String
  /// The department being charged for seats on this trip.
  departamentoId     String
  /// Number of CONFIRMED/PENDING PassengerSlots (or V1 Reservations) for this dept on this trip.
  asientosReservados Int
  /// This department's proportional share of the trip's empty seats (4 decimal places).
  fraccionVacios     Decimal  @db.Decimal(8, 4)
  /// Final liquidated seats: asientosReservados + fraccionVacios (4 decimal places).
  totalAsientos      Decimal  @db.Decimal(8, 4)
  /// Calendar month of the trip departure (1–12). Denormalized for monthly reporting.
  mes                Int
  /// Calendar year of the trip departure. Denormalized for monthly reporting.
  /// (Spelled "anio" to avoid Unicode `ñ` in identifiers.)
  anio               Int
  createdAt          DateTime @default(now())

  company      Company    @relation(fields: [companyId], references: [id])
  branch       Branch     @relation(fields: [branchId], references: [id])
  viaje        Trip       @relation(fields: [viajeId], references: [id])
  departamento Department @relation(fields: [departamentoId], references: [id])

  /// One settlement record per trip per department.
  @@unique([viajeId, departamentoId])
  /// Monthly liquidation summary per company.
  @@index([companyId, anio, mes])
  /// Monthly liquidation summary per branch.
  @@index([branchId, anio, mes])
  /// Monthly totals per department.
  @@index([departamentoId, anio, mes])
  /// All liquidation records for a specific trip.
  @@index([viajeId])
}

// =============================================================================
// RECOMENDACION IA — AI-generated operational efficiency recommendations
// =============================================================================

/// An operational efficiency recommendation generated by the UABL Assistant AI.
///
/// Generated by POSTing to /api/uabl/recomendaciones, which queries real operational
/// data for the period and calls the Claude AI to produce actionable suggestions.
///
/// LIFECYCLE
/// ---------
/// ACTIVA      → Just generated, awaiting review by UABL operators.
/// IMPLEMENTADA → The recommendation was accepted and acted upon.
/// DESCARTADA  → The recommendation was dismissed as not applicable.
///
/// Only one set of ACTIVA recommendations per (companyId, mes, anio) is kept at
/// a time. Generating new recommendations for a period deletes existing ACTIVA ones.
///
/// MULTI-TENANT: always scoped to companyId. No branch scope — these are company-wide.
model RecomendacionIA {
  id                     String              @id @default(cuid())
  companyId              String
  titulo                 String
  descripcion            String
  /// Estimated efficiency gain in seats per month if implemented.
  ahorroEstimadoAsientos Int
  prioridad              PrioridadIA
  estado                 EstadoRecomendacion @default(ACTIVA)
  /// Calendar month this recommendation was generated for (1–12).
  mes                    Int
  /// Calendar year this recommendation was generated for.
  anio                   Int
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, estado])
  @@index([companyId, anio, mes])
}

// =============================================================================
// RESERVATION (V1 LEGACY — DEPRECATED)
// =============================================================================

/// @deprecated Use GroupBooking + PassengerSlot for V2 booking flows.
/// This model is kept for migration safety. All existing records are
/// archived (status = CANCELLED) during the V2 data migration script.
/// This table will be dropped in a V3 cleanup migration.
///
/// The replacement chain design and single-active-reservation invariant
/// are documented here for historical reference. See PassengerSlot for V2 equivalents.
model Reservation {
  id        String            @id @default(cuid())
  companyId String
  branchId  String
  userId    String
  tripId    String
  status    ReservationStatus @default(CONFIRMED)

  replacesReservationId String? @unique

  /// V2 addition: links this legacy reservation to the UABL department responsible
  /// for the passenger (nullable — not set on pre-V2 records).
  /// Used by the liquidation module to attribute legacy seat consumption to a department.
  departamentoId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  trip         Trip         @relation(fields: [tripId], references: [id])
  departamento Department?  @relation("DepartmentReservation", fields: [departamentoId], references: [id])

  replacesReservation   Reservation?   @relation("ReplacementChain", fields: [replacesReservationId], references: [id])
  replacedByReservation Reservation?   @relation("ReplacementChain")
  promotedFromWaitlist  WaitlistEntry? @relation("WaitlistPromotion")
  checkIn               CheckIn?

  @@index([userId, status])
  @@index([tripId, status])
  @@index([companyId, userId])
  @@index([companyId, tripId])
  @@index([branchId, status])
  @@index([departamentoId])
}

// =============================================================================
// WAITLIST (V1 LEGACY — DEPRECATED)
// =============================================================================

/// @deprecated Use GroupBooking + PassengerSlot for V2 booking flows.
/// All existing WAITING entries are archived (status = EXPIRED) during the
/// V2 data migration script. This table will be dropped in a V3 cleanup migration.
model WaitlistEntry {
  id        String         @id @default(cuid())
  companyId String
  branchId  String
  userId    String
  tripId    String
  position  Int
  status    WaitlistStatus @default(WAITING)

  promotedToReservationId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  trip    Trip    @relation(fields: [tripId], references: [id])

  promotedToReservation Reservation? @relation("WaitlistPromotion", fields: [promotedToReservationId], references: [id])

  @@unique([tripId, position])
  @@index([tripId, status, position])
  @@index([userId, status])
  @@index([companyId, tripId])
}

// =============================================================================
// PORT STATUS
// =============================================================================

/// Real-time operational state of a branch / port.
/// APPEND-ONLY EVENT LOG — no updatedAt, records are immutable after creation.
/// Current status for a branch = most recent record ordered by createdAt DESC.
/// In V2, managed by PROVEEDOR users.
model PortStatus {
  id                   String          @id @default(cuid())
  companyId            String
  branchId             String
  status               PortStatusValue @default(OPEN)
  message              String?
  estimatedReopeningAt DateTime?
  setByUserId          String
  createdAt            DateTime        @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])
  setByUser User    @relation("PortStatusActor", fields: [setByUserId], references: [id])

  @@index([branchId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
}

// =============================================================================
// OPERATIONAL NOTICE
// =============================================================================

/// A public-facing message tied to a branch or a specific trip.
/// In V2, managed by PROVEEDOR and UABL users.
model OperationalNotice {
  id              String    @id @default(cuid())
  companyId       String
  branchId        String
  tripId          String?
  title           String
  message         String
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])
  trip      Trip?   @relation(fields: [tripId], references: [id])
  createdBy User    @relation(fields: [createdByUserId], references: [id])

  @@index([branchId, isActive])
  @@index([tripId, isActive])
  @@index([companyId, isActive, createdAt(sort: Desc)])
}

// =============================================================================
// CHECK-IN
// =============================================================================

/// Embarkation record for a passenger on a trip.
/// In V2, still linked to the legacy Reservation model for backwards compat.
/// Future: link to PassengerSlot instead.
model CheckIn {
  id                String   @id @default(cuid())
  companyId         String
  reservationId     String   @unique
  tripId            String
  userId            String
  checkedInByUserId String
  checkedInAt       DateTime @default(now())
  notes             String?

  company      Company     @relation(fields: [companyId], references: [id])
  reservation  Reservation @relation(fields: [reservationId], references: [id])
  trip         Trip        @relation(fields: [tripId], references: [id])
  checkedInBy  User        @relation("CheckInOperator", fields: [checkedInByUserId], references: [id])

  @@index([tripId])
  @@index([companyId, tripId])
}

// =============================================================================
// AUDIT LOG
// =============================================================================

/// Immutable append-only record of all operationally significant actions.
/// No updatedAt. The application layer must never issue UPDATE or DELETE
/// against this table.
model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String
  payload    Json
  ipAddress  String?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([companyId, action, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
}

// =============================================================================
// SNAPSHOT MENSUAL
// =============================================================================

/// Immutable monthly aggregate snapshot for period comparison and AI analysis.
/// One record per company per calendar month. Idempotent: re-running the job
/// overwrites the record and resets generadoEn.
///
/// Fields:
///   distribucionDeptos  — { [deptName]: totalSlots }  (PENDING + CONFIRMED)
///   viajesPorDia        — { [YYYY-MM-DD]: { viajes, ocupacion } }
///   promedioOcupacion   — ratio 0.0–1.0 (mean of per-trip occupied/capacity)
///   cancelaciones       — trips with viajeStatus = CANCELADO
///   viajesBajaOcupacion — non-cancelled trips with occupancy ratio < 0.40
model SnapshotMensual {
  id                    String   @id @default(cuid())
  companyId             String
  branchId              String?
  mes                   Int
  anio                  Int
  totalViajes           Int
  totalAsientosOcupados Decimal  @db.Decimal(10, 2)
  totalAsientosVacios   Decimal  @db.Decimal(10, 2)
  promedioOcupacion     Decimal  @db.Decimal(5, 4)
  distribucionDeptos    Json
  viajesPorDia          Json
  cancelaciones         Int
  viajesBajaOcupacion   Int
  generadoEn            DateTime @default(now())
  cerrado               Boolean  @default(true)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, mes, anio])
  @@index([companyId, anio, mes])
}

// =============================================================================
// INFORME NARRATIVO — Monthly executive report generated by Claude AI
// =============================================================================
//
// Each company can have one narrative report per calendar month.
// Generated via POST /api/informes. Idempotent: regenerating overwrites the text.
// generadoEn is updated on each regeneration.
//
// MULTI-TENANT: always scoped to companyId.
/// AI-generated monthly executive narrative for UABL operators.
/// Synthesises snapshot, anomalies, and recommendations into a 300-word brief.
model InformeNarrativo {
  id          String   @id @default(cuid())
  companyId   String
  /// Calendar month (1–12).
  mes         Int
  /// Calendar year.
  anio        Int
  /// Markdown text generated by Claude. May be up to ~2 000 chars.
  contenido   String   @db.Text
  generadoEn  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, mes, anio])
  @@index([companyId, anio, mes])
}

// =============================================================================
// RAW MIGRATION NOTES
// =============================================================================
//
// The following constraints CANNOT be expressed in Prisma schema syntax.
// They must be added as raw SQL in the generated migration file.
//
// ── 1. TRIP CAPACITY ENFORCEMENT (APPLICATION-LAYER NOTE) ───────────────────
//
//   V2 capacity check at booking time must use:
//     SELECT COUNT(*) FROM "PassengerSlot"
//     WHERE "tripId" = $tripId
//     AND status IN ('PENDING', 'CONFIRMED')
//     -- inside a transaction that also locks the Trip row:
//     SELECT id FROM "Trip" WHERE id = $tripId FOR UPDATE
//
//   PENDING slots hold capacity (tentatively reserved while awaiting UABL).
//   REJECTED and CANCELLED slots release capacity.
//
// ── 2. V1 LEGACY CONSTRAINTS (kept for existing data) ────────────────────────
//
//   These indexes exist in production from V1 and must not be dropped:
//
//   CREATE UNIQUE INDEX reservation_one_active_per_user
//   ON "Reservation" ("userId", "companyId")
//   WHERE status IN ('CONFIRMED', 'WAITLISTED', 'CHECKED_IN');
//
//   CREATE UNIQUE INDEX waitlist_one_waiting_per_user_per_trip
//   ON "WaitlistEntry" ("userId", "tripId")
//   WHERE status = 'WAITING';
//
// ── 3. V2 USUARIOASSIGNMENT UNIQUENESS ────────────────────────────────────────
//
//   The @@unique([tripId, usuarioId]) on PassengerSlot is expressed in Prisma
//   and handled by the standard migration. No raw SQL needed.
//
// =============================================================================
