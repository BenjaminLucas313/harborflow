// =============================================================================
// HarborFlow — Prisma Schema V2
// Multi-tenant launch reservation and operations platform
//
// DOMAIN SHIFT FROM V1
// --------------------
// V1: individual passengers (PASSENGER) self-book trips.
// V2: companies (COMPANY_REP) assign employees (EMPLOYEE) to seats.
//     UABL_STAFF confirms assignments by department.
//     PROVIDER manages fleet, schedules, and port status.
//
// DESIGN PRINCIPLES
// -----------------
// 1. Every tenant-owned entity carries companyId. Branch-scoped entities
//    additionally carry branchId (sometimes denormalized for query efficiency).
// 2. TripStatus does NOT include FULL. Full/availability is always derived
//    by counting PENDING + CONFIRMED SeatRequests against trip.capacity.
//    Storing FULL creates desync risk on changes.
// 3. Trip.capacity is a snapshot of Boat.capacity at trip creation time.
//    This prevents boat edits from retroactively invalidating trip data.
// 4. PENDING + CONFIRMED SeatRequests count against capacity.
//    UABL rejection of a PENDING seat releases that capacity.
//    This prevents oversell while giving UABL the ability to reject.
// 5. PortStatus is an append-only event log. Current status = latest record
//    for a branch ordered by createdAt DESC. No updatedAt.
// 6. AuditLog is immutable. No updates, no deletes. actorId is nullable
//    to support system-triggered events.
// 7. Employee uniqueness per trip is enforced at the application layer
//    (no partial index with JOIN in PostgreSQL predicates):
//    before creating a SeatRequest, check that employeeId has no
//    PENDING or CONFIRMED seat on the same trip across any allocation.
// 8. The old Reservation and WaitlistEntry models are retained as legacy
//    for historical data. New bookings use TripAllocation + SeatRequest.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

/// Roles for V2.
/// EMPLOYEE     = worker/inspector/businessperson — passive, can only view assigned trips.
/// COMPANY_REP  = employer representative — requests seats and assigns employees.
/// UABL_STAFF   = port authority personnel (departmentalized) — confirms/rejects seats.
/// PROVIDER     = vessel owner/operator — manages fleet, schedules, port status.
///
/// MIGRATION NOTE: PASSENGER → EMPLOYEE, OPERATOR → UABL_STAFF, ADMIN → PROVIDER.
/// Run migration SQL before dropping old values (see migration notes at bottom).
enum UserRole {
  EMPLOYEE
  COMPANY_REP
  UABL_STAFF
  PROVIDER
}

/// Lifecycle of a single seat assignment within a TripAllocation.
/// PENDING  — blue on the UABL seat map — submitted, awaiting UABL confirmation.
/// CONFIRMED — green — UABL department approved this seat.
/// REJECTED — UABL rejected (with optional note). Capacity is released.
/// CANCELLED — company removed the seat before or after UABL confirmation.
enum SeatRequestStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

/// Lifecycle of a company's allocation (batch seat request) for a trip.
/// DRAFT               — company is building the request, not yet submitted to UABL.
/// SUBMITTED           — sent to UABL for review; individual seats transition to PENDING.
/// PARTIALLY_CONFIRMED — some seats confirmed, some still PENDING or REJECTED.
/// FULLY_CONFIRMED     — all seats are CONFIRMED.
/// CANCELLED           — company cancelled the entire allocation.
enum AllocationStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_CONFIRMED
  FULLY_CONFIRMED
  CANCELLED
}

/// Operational lifecycle of a scheduled trip.
/// FULL is intentionally absent — it is a derived state, not stored.
/// BOARDING: check-in has opened. Seat requests are still valid.
/// DELAYED: departure pushed back. Allocations remain active.
/// CANCELLED: terminal state.
/// DEPARTED / COMPLETED: terminal operational states.
enum TripStatus {
  SCHEDULED
  BOARDING
  DELAYED
  CANCELLED
  DEPARTED
  COMPLETED
}

/// Legacy: kept for historical Reservation records from V1.
enum ReservationStatus {
  CONFIRMED
  WAITLISTED
  REPLACED
  CANCELLED
  CHECKED_IN
  NO_SHOW
}

/// Legacy: kept for historical WaitlistEntry records from V1.
enum WaitlistStatus {
  WAITING
  PROMOTED
  CANCELLED
  EXPIRED
}

/// Operational state values for a port / branch.
enum PortStatusValue {
  OPEN
  PARTIALLY_OPEN
  CLOSED_WEATHER
  CLOSED_MAINTENANCE
  CLOSED_SECURITY
  CLOSED_OTHER
}

/// Strongly-typed audit action catalog.
enum AuditAction {
  // Allocation lifecycle (V2)
  ALLOCATION_CREATED
  ALLOCATION_SUBMITTED
  ALLOCATION_CANCELLED
  SEAT_REQUEST_ADDED
  SEAT_CONFIRMED
  SEAT_REJECTED
  SEAT_CANCELLED
  EMPLOYEE_ASSIGNED
  // Legacy reservation lifecycle (V1 — do not remove, historical records reference these)
  RESERVATION_CREATED
  RESERVATION_REPLACED
  RESERVATION_CANCELLED
  RESERVATION_CHECKED_IN
  RESERVATION_NO_SHOW
  // Legacy waitlist lifecycle (V1)
  WAITLIST_JOINED
  WAITLIST_PROMOTED
  WAITLIST_CANCELLED
  WAITLIST_EXPIRED
  // Trip operations
  TRIP_CREATED
  TRIP_STATUS_CHANGED
  TRIP_CAPACITY_CHANGED
  // Vessel operations (V2)
  VESSEL_CREATED
  VESSEL_UPDATED
  // Port operations
  PORT_STATUS_CHANGED
  PORT_OPENED
  PORT_CLOSED
  // Notices
  NOTICE_CREATED
  NOTICE_DEACTIVATED
  // User / role management
  USER_CREATED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
}

// =============================================================================
// TENANT LAYER — Company & Branch
// =============================================================================

/// Top-level tenant. All tenant-owned entities carry companyId.
/// In V2, tenants represent distinct organizations:
///   - The PROVIDER company (vessel owner)
///   - The UABL company (port authority)
///   - Employer companies (each COMPANY_REP and EMPLOYEE belongs to one)
model Company {
  id        String   @id @default(cuid())
  name      String
  /// URL-safe unique identifier (e.g. "harbor-norte"). Used for routing.
  slug      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches            Branch[]
  users               User[]
  boats               Boat[]
  drivers             Driver[]
  trips               Trip[]
  // V1 legacy
  reservations        Reservation[]
  waitlistEntries     WaitlistEntry[]
  portStatuses        PortStatus[]
  operationalNotices  OperationalNotice[]
  checkIns            CheckIn[]
  auditLogs           AuditLog[]
  // V2
  allocations         TripAllocation[]
}

/// Operational location (port / dock / service point) within a company.
model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  boats              Boat[]
  drivers            Driver[]
  trips              Trip[]
  portStatuses       PortStatus[]
  operationalNotices OperationalNotice[]
  users              User[]

  @@index([companyId])
}

// =============================================================================
// USER
// =============================================================================

/// Users are always scoped to a company.
/// The same physical person at two different companies has two distinct accounts.
/// Email uniqueness is enforced per company, not globally.
///
/// departmentId: used only for UABL_STAFF. Scopes their confirmation authority
///   to that department's WorkTypes.
///
/// branchId: optional, primarily for UABL_STAFF or PROVIDER users scoped to a
///   specific branch/dock.
model User {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String?
  /// UABL_STAFF only: which department this user belongs to.
  departmentId String?
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  branch     Branch?     @relation(fields: [branchId], references: [id])
  department Department? @relation("UablStaffDepartment", fields: [departmentId], references: [id])

  // V1 legacy relations
  reservations        Reservation[]
  waitlistEntries     WaitlistEntry[]
  checkInsPerformed   CheckIn[]           @relation("CheckInOperator")
  portStatusChanges   PortStatus[]        @relation("PortStatusActor")
  noticesCreated      OperationalNotice[]
  auditLogsAsActor    AuditLog[]          @relation("AuditActor")
  // V2 relations
  seatRequestsAsEmployee   SeatRequest[]    @relation("EmployeeSeatRequests")
  confirmedSeatRequests    SeatRequest[]    @relation("UablConfirmations")
  allocationRequests       TripAllocation[] @relation("AllocationRequester")
  notifications            Notification[]

  /// Email must be unique within a company (not globally).
  @@unique([companyId, email])
  @@index([companyId, role])
  @@index([companyId, branchId])
  /// EMPLOYEE search by employer company: COMPANY_REP searches within their companyId.
  @@index([companyId, role, isActive])
}

// =============================================================================
// UABL DOMAIN — Department & WorkType
// =============================================================================

/// UABL internal organizational unit. Each department confirms seat requests
/// for work types that belong to it.
///
/// Departments are seeded by administrators — this is a closed, managed list.
/// Each UABL_STAFF user is assigned to exactly one department via User.departmentId.
model Department {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workTypes    WorkType[]
  /// UABL staff members assigned to this department.
  uablStaff    User[]        @relation("UablStaffDepartment")
  seatRequests SeatRequest[] @relation("SeatRequestDepartment")

  @@index([isActive])
}

/// Category of work an employee performs at the destination.
/// Each WorkType belongs to exactly one Department.
///
/// When a COMPANY_REP assigns a seat, they select a WorkType.
/// This determines which UABL department must confirm that seat.
///
/// WorkTypes are a managed closed list — created by PROVIDER or a system admin.
model WorkType {
  id           String  @id @default(cuid())
  departmentId String
  name         String
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department    @relation(fields: [departmentId], references: [id])
  seatRequests SeatRequest[]

  @@index([departmentId])
  @@index([departmentId, isActive])
}

// =============================================================================
// TRIP ALLOCATION — V2 Booking Paradigm
// =============================================================================

/// A company's batch seat request for a specific trip.
///
/// A COMPANY_REP creates a TripAllocation in DRAFT status, adds SeatRequests
/// (one per employee), then submits the allocation to UABL for confirmation.
///
/// Multiple companies can have allocations for the same trip.
/// There is no limit on how many allocations a company can create per day.
///
/// CAPACITY ENFORCEMENT
/// --------------------
/// Capacity is checked at SeatRequest creation time (not submission time).
/// PENDING + CONFIRMED SeatRequests count against trip.capacity.
/// This is enforced inside a transaction with FOR UPDATE on the Trip row.
/// UABL rejection releases that seat's capacity.
model TripAllocation {
  id            String           @id @default(cuid())
  /// The employer company making this request.
  companyId     String
  tripId        String
  /// The COMPANY_REP who created and manages this allocation.
  requestedById String
  status        AllocationStatus @default(DRAFT)
  /// Timestamp when the allocation was submitted to UABL (status → SUBMITTED).
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  trip         Trip          @relation(fields: [tripId], references: [id])
  requestedBy  User          @relation("AllocationRequester", fields: [requestedById], references: [id])
  seatRequests SeatRequest[]

  /// UABL view: all allocations for a trip by status.
  @@index([tripId, status])
  /// COMPANY_REP view: all allocations by this company.
  @@index([companyId, status])
  @@index([requestedById])
}

/// A single seat assignment within a TripAllocation.
/// Each SeatRequest assigns one EMPLOYEE to one seat with one WorkType.
///
/// STATUS FLOW
/// -----------
///   DRAFT allocation → add SeatRequest (PENDING on submit, no status yet in DRAFT)
///   On allocation SUBMITTED → all SeatRequests become PENDING
///   UABL confirms  → CONFIRMED
///   UABL rejects   → REJECTED (capacity released)
///   Company removes → CANCELLED (if not already CONFIRMED)
///
/// DEPARTMENT SCOPE
/// ----------------
/// departmentId is denormalized from workType.departmentId at creation time.
/// This allows UABL_STAFF to query seats for their department directly without
/// a JOIN through WorkType, and enforces that only the correct department
/// can confirm or reject this seat.
///
/// EMPLOYEE NOTIFICATION
/// ---------------------
/// notifiedAt is set when the employee receives their assignment notification.
/// Notifications are created in src/modules/notifications/ as fire-and-forget.
model SeatRequest {
  id            String            @id @default(cuid())
  allocationId  String
  /// The employee assigned to this seat. Must have role=EMPLOYEE in the same company.
  employeeId    String
  workTypeId    String
  /// Denormalized from workType.departmentId for direct UABL department queries.
  departmentId  String
  status        SeatRequestStatus @default(PENDING)
  /// UABL_STAFF who confirmed or rejected this seat.
  confirmedById String?
  confirmedAt   DateTime?
  /// Optional note from UABL when rejecting.
  rejectionNote String?
  /// When the employee was last notified of a status change.
  notifiedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  allocation  TripAllocation @relation(fields: [allocationId], references: [id])
  employee    User           @relation("EmployeeSeatRequests", fields: [employeeId], references: [id])
  workType    WorkType       @relation(fields: [workTypeId], references: [id])
  department  Department     @relation("SeatRequestDepartment", fields: [departmentId], references: [id])
  confirmedBy User?          @relation("UablConfirmations", fields: [confirmedById], references: [id])

  /// Allocation detail: all seats and their statuses.
  @@index([allocationId, status])
  /// Employee's trip history.
  @@index([employeeId, status])
  /// UABL department queue: all seats pending/confirmed for a department.
  @@index([departmentId, status])
  @@index([workTypeId])
}

// =============================================================================
// NOTIFICATION
// =============================================================================

/// In-app and email notification record for status events.
///
/// Created as fire-and-forget (non-blocking) after seat assignment/confirmation/rejection.
/// The payload contains enough data to compose an email without extra DB lookups:
///   { tripId, departureTime, companyName, seatRequestId, allocationId }
///
/// An async job or Vercel cron can process unread notifications older than N
/// minutes and send emails (V2 extension point — wiring left to deployment config).
model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// "SEAT_ASSIGNED" | "SEAT_CONFIRMED" | "SEAT_REJECTED" | "SEAT_CANCELLED"
  type      String
  /// JSON payload with context for the notification (tripId, departureTime, etc.)
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  /// Unread notifications for a user (primary bell/badge query).
  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

// =============================================================================
// FLEET — Boat & Driver
// =============================================================================

/// A vessel belonging to a company (typically the PROVIDER's company) and assigned to a branch.
/// capacity is the master value from which Trip.capacity is snapshotted.
/// Changing capacity here does NOT retroactively change existing trips.
model Boat {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String
  name        String
  /// Maximum passenger capacity for this vessel.
  capacity    Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  trips   Trip[]

  @@index([companyId])
  @@index([branchId])
}

/// A pilot / captain assigned to trips.
model Driver {
  id            String   @id @default(cuid())
  companyId     String
  branchId      String
  firstName     String
  lastName      String
  licenseNumber String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  trips   Trip[]

  @@index([companyId])
  @@index([branchId])
}

// =============================================================================
// TRIP
// =============================================================================

/// A scheduled departure. The core reservable unit.
///
/// capacity is a SNAPSHOT of boat.capacity at the time of trip creation.
/// This is intentional: boat edits must not affect existing allocations.
///
/// waitlistEnabled is retained for compatibility but not used in V2 allocation flow.
model Trip {
  id                   String     @id @default(cuid())
  companyId            String
  branchId             String
  boatId               String
  driverId             String?
  departureTime        DateTime
  estimatedArrivalTime DateTime?
  status               TripStatus @default(SCHEDULED)
  /// Snapshot of boat.capacity at trip creation.
  capacity             Int
  waitlistEnabled      Boolean    @default(true)
  statusReason         String?
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  branch             Branch              @relation(fields: [branchId], references: [id])
  boat               Boat                @relation(fields: [boatId], references: [id])
  driver             Driver?             @relation(fields: [driverId], references: [id])
  operationalNotices OperationalNotice[]
  // V1 legacy
  reservations       Reservation[]
  waitlistEntries    WaitlistEntry[]
  checkIns           CheckIn[]
  // V2
  allocations        TripAllocation[]

  @@index([branchId, departureTime, status])
  @@index([companyId, departureTime])
  @@index([companyId, status])
}

// =============================================================================
// RESERVATION (V1 LEGACY — retained for historical records)
// =============================================================================

/// Legacy V1 booking model. Retained for historical data only.
/// New bookings use TripAllocation + SeatRequest.
model Reservation {
  id        String            @id @default(cuid())
  companyId String
  branchId  String
  userId    String
  tripId    String
  status    ReservationStatus @default(CONFIRMED)

  replacesReservationId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  trip    Trip    @relation(fields: [tripId], references: [id])

  replacesReservation   Reservation? @relation("ReplacementChain", fields: [replacesReservationId], references: [id])
  replacedByReservation Reservation? @relation("ReplacementChain")

  promotedFromWaitlist WaitlistEntry? @relation("WaitlistPromotion")
  checkIn              CheckIn?

  @@index([userId, status])
  @@index([tripId, status])
  @@index([companyId, userId])
  @@index([companyId, tripId])
  @@index([branchId, status])
}

// =============================================================================
// WAITLIST (V1 LEGACY — retained for historical records)
// =============================================================================

/// Legacy V1 waitlist model. Retained for historical data only.
model WaitlistEntry {
  id        String        @id @default(cuid())
  companyId String
  branchId  String
  userId    String
  tripId    String
  position  Int
  status    WaitlistStatus @default(WAITING)

  promotedToReservationId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  trip    Trip    @relation(fields: [tripId], references: [id])

  promotedToReservation Reservation? @relation("WaitlistPromotion", fields: [promotedToReservationId], references: [id])

  @@unique([tripId, position])
  @@index([tripId, status, position])
  @@index([userId, status])
  @@index([companyId, tripId])
}

// =============================================================================
// PORT STATUS
// =============================================================================

/// Real-time operational state of a branch / port.
/// Managed by PROVIDER users (and optionally UABL_STAFF).
///
/// Append-only event log design. Current status = most recent record
/// ordered by createdAt DESC.
model PortStatus {
  id                   String          @id @default(cuid())
  companyId            String
  branchId             String
  status               PortStatusValue @default(OPEN)
  message              String?
  estimatedReopeningAt DateTime?
  setByUserId          String
  createdAt            DateTime        @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])
  setByUser User    @relation("PortStatusActor", fields: [setByUserId], references: [id])

  @@index([branchId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
}

// =============================================================================
// OPERATIONAL NOTICE
// =============================================================================

/// A public-facing message tied to a branch or a specific trip.
model OperationalNotice {
  id              String    @id @default(cuid())
  companyId       String
  branchId        String
  tripId          String?
  title           String
  message         String
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])
  trip      Trip?   @relation(fields: [tripId], references: [id])
  createdBy User    @relation(fields: [createdByUserId], references: [id])

  @@index([branchId, isActive])
  @@index([tripId, isActive])
  @@index([companyId, isActive, createdAt(sort: Desc)])
}

// =============================================================================
// CHECK-IN (V1 LEGACY — retained for historical records)
// =============================================================================

/// Legacy V1 embarkation record.
model CheckIn {
  id                String   @id @default(cuid())
  companyId         String
  reservationId     String   @unique
  tripId            String
  userId            String
  checkedInByUserId String
  checkedInAt       DateTime @default(now())
  notes             String?

  company     Company     @relation(fields: [companyId], references: [id])
  reservation Reservation @relation(fields: [reservationId], references: [id])
  trip        Trip        @relation(fields: [tripId], references: [id])
  checkedInBy User        @relation("CheckInOperator", fields: [checkedInByUserId], references: [id])

  @@index([tripId])
  @@index([companyId, tripId])
}

// =============================================================================
// AUDIT LOG
// =============================================================================

/// Immutable append-only record of all operationally significant actions.
model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String
  payload    Json
  ipAddress  String?
  createdAt  DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id])
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([companyId, action, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([companyId, createdAt(sort: Desc)])
}

// =============================================================================
// RAW MIGRATION NOTES
// =============================================================================
//
// ── 1. ENUM MIGRATION: UserRole ─────────────────────────────────────────────
//
//   Since Prisma cannot rename enum values, the generated migration file must
//   include UPDATE statements before the USING clause in the ALTER COLUMN:
//
//   UPDATE "User" SET role = 'EMPLOYEE'   WHERE role = 'PASSENGER';
//   UPDATE "User" SET role = 'UABL_STAFF' WHERE role = 'OPERATOR';
//   UPDATE "User" SET role = 'PROVIDER'   WHERE role = 'ADMIN';
//
//   These must run BEFORE Prisma's generated:
//     ALTER TABLE "User" ALTER COLUMN "role" TYPE "UserRole_new"
//     USING ("role"::text::"UserRole_new");
//
//   See prisma/migrations/TIMESTAMP_restructure_user_roles/migration.sql
//
// ── 2. EMPLOYEE UNIQUENESS PER TRIP (APPLICATION-LAYER NOTE) ────────────────
//
//   Before creating a SeatRequest, the service must verify:
//     SELECT COUNT(*) FROM "SeatRequest" sr
//     JOIN "TripAllocation" ta ON ta.id = sr."allocationId"
//     WHERE ta."tripId" = $tripId
//       AND sr."employeeId" = $employeeId
//       AND sr.status IN ('PENDING', 'CONFIRMED')
//   If count > 0, reject with EMPLOYEE_ALREADY_ON_TRIP.
//
//   PostgreSQL does not support JOINs in partial index predicates,
//   so this is enforced at the application service layer.
//
// ── 3. CAPACITY ENFORCEMENT ─────────────────────────────────────────────────
//
//   When adding a SeatRequest to a DRAFT allocation, the service must:
//     SELECT COUNT(*) FROM "SeatRequest" sr
//     JOIN "TripAllocation" ta ON ta.id = sr."allocationId"
//     WHERE ta."tripId" = $tripId
//       AND sr.status IN ('PENDING', 'CONFIRMED')
//     FOR UPDATE on "Trip"
//   If count >= trip.capacity, reject with TRIP_CAPACITY_FULL.
//
// ── 4. LEGACY INDEX REMOVAL ─────────────────────────────────────────────────
//
//   If migrating from a live V1 deployment with these indexes, drop them:
//
//   DROP INDEX IF EXISTS reservation_one_active_per_user;
//   DROP INDEX IF EXISTS waitlist_one_waiting_per_user_per_trip;
//
// =============================================================================
